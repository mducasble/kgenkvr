# =====================================================
# RecordingApp — Environment Variables
# =====================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── App ──────────────────────────────────────────────
NODE_ENV=development

# ── Daily.co ─────────────────────────────────────────
# Your Daily.co API key from https://dashboard.daily.co/
DAILY_API_KEY=

# Your Daily.co domain (subdomain only, e.g. "mycompany")
DAILY_DOMAIN=

# ── ElevenLabs ───────────────────────────────────────
# Your ElevenLabs API key from https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ── Upload ───────────────────────────────────────────
# Backend endpoint that accepts recording uploads
# Can be an S3 presigned URL generator or your own API
UPLOAD_ENDPOINT=

# ── Backend API ──────────────────────────────────────
# Your app's backend API URL (if separate from Electron)
API_BASE_URL=http://localhost:3000

# ── Storage ──────────────────────────────────────────
# Override the default recordings output directory
# Default: Electron userData path / recordings
RECORDINGS_DIR=
